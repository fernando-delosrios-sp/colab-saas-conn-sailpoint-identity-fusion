{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "chain.schema.json",
  "title": "Chain Test Scenario",
  "description": "Defines a chain test scenario with config, initial state, steps, and reference values.",
  "type": "object",
  "required": ["version", "config", "steps"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Scenario format version (semver)"
    },
    "config": {
      "type": "object",
      "description": "Fusion configuration for the scenario",
      "required": ["sources"],
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "sourceType": { "type": "string", "enum": ["authoritative", "record", "orphan"] },
              "correlationMode": { "type": "string", "enum": ["correlate", "reverse", "none"] },
              "correlationAttribute": { "type": "string" },
              "correlationDisplayName": { "type": "string" },
              "deferredMatching": { "type": "boolean" },
              "accountJmespathFilter": { "type": "string" },
              "disableNonMatchingAccounts": { "type": "boolean" },
              "aggregationMode": { "type": "string", "enum": ["none", "before", "delayed"] },
              "aggregationDelay": { "type": "number" },
              "optimizedAggregation": { "type": "boolean" }
            }
          }
        },
        "uniqueAttributeDefinitions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "expression"],
            "properties": {
              "name": { "type": "string" },
              "expression": { "type": "string" },
              "case": { "type": "string", "enum": ["same", "lower", "upper", "capitalize"] },
              "useIncrementalCounter": { "type": "boolean" },
              "counterStart": { "type": "number" },
              "digits": { "type": "number" },
              "maxLength": { "type": "number" },
              "normalize": { "type": "boolean" },
              "spaces": { "type": "boolean" },
              "trim": { "type": "boolean" }
            }
          }
        },
        "normalAttributeDefinitions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "expression"],
            "properties": {
              "name": { "type": "string" },
              "expression": { "type": "string" },
              "refresh": { "type": "boolean" },
              "case": { "type": "string", "enum": ["same", "lower", "upper", "capitalize"] },
              "maxLength": { "type": "number" },
              "normalize": { "type": "boolean" },
              "spaces": { "type": "boolean" },
              "trim": { "type": "boolean" }
            }
          }
        },
        "attributeMaps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["newAttribute", "existingAttributes"],
            "properties": {
              "newAttribute": { "type": "string" },
              "existingAttributes": {
                "type": "array",
                "items": { "type": "string" }
              },
              "attributeMerge": { "type": "string", "enum": ["first", "list", "concatenate", "source"] },
              "source": { "type": "string" }
            }
          }
        },
        "matchingConfigs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["attribute"],
            "properties": {
              "attribute": { "type": "string" },
              "algorithm": { "type": "string" },
              "fusionScore": { "type": "number" },
              "mandatory": { "type": "boolean" }
            }
          }
        },
        "fusionAverageScore": { "type": "number" },
        "fusionMergingExactMatch": { "type": "boolean" },
        "fusionOwnerIsGlobalReviewer": { "type": "boolean" },
        "fusionFormExpirationDays": { "type": "number" },
        "fusionReportOnAggregation": { "type": "boolean" },
        "includeIdentities": { "type": "boolean" },
        "deleteEmpty": { "type": "boolean" },
        "skipAccountsWithMissingId": { "type": "boolean" },
        "maxHistoryMessages": { "type": "number" },
        "maxAttempts": { "type": "number" },
        "reset": { "type": "boolean" },
        "forceAttributeRefresh": { "type": "boolean" }
      }
    },
    "initialState": {
      "type": "object",
      "description": "Initial platform data before any steps execute",
      "properties": {
        "identities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "attributes": { "type": "object" },
              "accounts": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "source": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string" },
                        "name": { "type": "string" }
                      }
                    },
                    "accountId": { "type": "string" },
                    "nativeIdentity": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "managedAccounts": {
          "type": "object",
          "description": "Managed accounts keyed by pass label (pass1, pass2, …). Use an array of account maps where order matters per pass.",
          "patternProperties": {
            "^pass\\d+$": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "sourceName"],
                "properties": {
                  "id": { "type": "string" },
                  "sourceName": { "type": "string" },
                  "nativeIdentity": { "type": "string" },
                  "name": { "type": "string" },
                  "disabled": { "type": "boolean" },
                  "attributes": { "type": "object" },
                  "identity": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string" },
                      "name": { "type": "string" }
                    }
                  },
                  "sourceOwner": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string" },
                      "name": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        },
        "fusionAccounts": {
          "type": "array",
          "description": "Pre-existing Fusion accounts in the connector datasource",
          "items": {
            "type": "object",
            "required": ["nativeIdentity"],
            "properties": {
              "nativeIdentity": { "type": "string" },
              "identityId": { "type": "string" },
              "name": { "type": "string" },
              "displayName": { "type": "string" },
              "disabled": { "type": "boolean" },
              "attributes": { "type": "object" },
              "statuses": {
                "type": "array",
                "items": { "type": "string" }
              },
              "actions": {
                "type": "array",
                "items": { "type": "string" }
              },
              "reviews": {
                "type": "array",
                "items": { "type": "string" }
              },
              "sources": {
                "type": "array",
                "items": { "type": "string" }
              },
              "accountIds": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "forms": {
          "type": "array",
          "description": "Pre-existing form instances (review decisions)",
          "items": {
            "type": "object",
            "required": ["id", "state"],
            "properties": {
              "id": { "type": "string" },
              "state": {
                "type": "string",
                "enum": ["ASSIGNED", "IN_PROGRESS", "SUBMITTED", "COMPLETED", "CANCELLED"]
              },
              "formInput": {
                "type": "object",
                "properties": {
                  "account": { "type": "string" }
                }
              },
              "formData": {
                "type": "object",
                "properties": {
                  "identities": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "newIdentity": { "type": "boolean" },
                  "comments": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "description": "Ordered sequence of operation steps to execute",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "operation"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique step identifier (e.g. step-1)"
          },
          "operation": {
            "type": "string",
            "description": "Connector operation to execute",
            "enum": [
              "accountDiscoverSchema",
              "accountList",
              "accountCreate",
              "accountRead",
              "accountUpdate",
              "accountEnable",
              "accountDisable",
              "entitlementList"
            ]
          },
          "pass": {
            "type": "integer",
            "description": "Aggregation pass number (1 or 2) for accountList steps"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of what this step validates"
          },
          "input": {
            "type": "object",
            "description": "Operation input. Supports $state references for value interpolation."
          },
          "mockDelegate": {
            "type": "string",
            "description": "Named mock delegate to activate before this step"
          },
          "expectedOutput": {
            "type": "object",
            "description": "Expected output shape (supports partial matching with JMESPath)"
          },
          "expectedStateDelta": {
            "type": "object",
            "description": "Expected state changes after this step"
          }
        }
      }
    },
    "referenceValues": {
      "type": "object",
      "description": "Reference/expected values after key steps for snapshot comparison",
      "additionalProperties": {
        "type": "object"
      }
    }
  }
}
