  "steps": [
    {
      "id": "step-1",
      "operation": "accountDiscoverSchema",
      "description": "Schema discovery returns current source schema",
      "expectedOutput": {
        "attributes": [
          { "name": "displayName" },
          { "name": "email" },
          { "name": "employeeId" },
          { "name": "department" }
        ]
      }
    },
    {
      "id": "step-2",
      "operation": "entitlementList",
      "description": "Entitlement list returns status + action entitlements",
      "input": { "type": "status" },
      "expectedOutput": {
        "entitlements": [
          { "attribute": "statuses", "value": "enabled" },
          { "attribute": "statuses", "value": "disabled" }
        ]
      }
    },
    {
      "id": "step-3",
      "operation": "entitlementList",
      "description": "Action entitlements include managed source reviewers",
      "input": { "type": "action" },
      "expectedOutput": {
        "entitlements": [
          { "attribute": "actions", "value": "correlate" }
        ]
      }
    },
    {
      "id": "step-4",
      "operation": "accountList",
      "pass": 1,
      "description": "First aggregation: one authoritative source, matches and deferred matches",
      "expectedOutput": {
        "outputCount": 5,
        "identitiesFound": 4,
        "correlatedCount": 3,
        "unmatchedCount": 2
      }
    },
    {
      "id": "step-5",
      "operation": "accountCreate",
      "description": "Create a new Fusion account from Carol Admin identity",
      "input": {
        "identity": "Carol Admin",
        "attributes": {
          "name": "Carol Admin",
          "actions": ["correlate:identity-carol"]
        }
      },
      "expectedOutput": {
        "identityLinked": true,
        "actionsExecuted": 1
      }
    },
    {
      "id": "step-6",
      "operation": "accountList",
      "pass": 2,
      "description": "Second aggregation: additional source, deferred matches become matches",
      "expectedOutput": {
        "outputCount": 4,
        "identitiesFound": 5,
        "correlatedCount": 3,
        "unmatchedCount": 2
      }
    },
    {
      "id": "step-7",
      "operation": "accountDisable",
      "description": "Disable an existing Fusion account",
      "input": {
        "identity": "fusion-identity-carol"
      },
      "expectedOutput": {
        "disabled": true,
        "attributesPreserved": true
      }
    },
    {
      "id": "step-8",
      "operation": "accountEnable",
      "description": "Enable account: unique attributes should be refreshed (changed)",
      "input": {
        "identity": "fusion-identity-alice",
        "schema": { "attributes": [] }
      },
      "expectedOutput": {
        "enabled": true,
        "uniqueAttributesRefreshed": true
      }
    },
    {
      "id": "step-9",
      "operation": "accountRead",
      "description": "Read account: unique attributes should NOT be refreshed (unchanged)",
      "input": {
        "identity": "fusion-identity-alice",
        "schema": { "attributes": [] }
      },
      "expectedOutput": {
        "identityFound": true,
        "uniqueAttributesUnchanged": true
      }
    },
    {
      "id": "step-10",
      "operation": "accountUpdate",
      "description": "Update entitlements: add correlate action",
      "input": {
        "identity": "fusion-identity-bob",
        "schema": { "attributes": [] },
        "changes": [
          { "attribute": "actions", "op": "Add", "value": "correlate:identity-bob" }
        ]
      },
      "expectedOutput": {
        "entitlementChanged": true,
        "correlationRecomputed": true
      }
    }
  ],
  "referenceValues": {
    "step-4": {
      "expectedCorrelatedCount": 3,
      "expectedNewFusionCount": 5,
      "expectedDeferredCount": 0,
      "expectedUnmatchedCount": 2
    },
    "step-6": {
      "expectedCorrelatedCount": 3,
      "expectedDeferredConverted": 1,
      "expectedNewFusionCount": 1,
      "expectedUnmatchedCount": 2
    },
    "step-8": {
      "uniqueAttributeChanged": true,
      "employeeIdRegenerated": true,
      "aliasRegenerated": true,
      "normalAttributesUpdated": true
    },
    "step-9": {
      "uniqueAttributeUnchanged": true,
      "employeeIdPreserved": true,
      "aliasPreserved": true,
      "normalAttributesUpdated": true
    }
  }
}
