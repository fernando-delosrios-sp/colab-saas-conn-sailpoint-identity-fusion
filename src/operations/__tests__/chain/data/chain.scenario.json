{
  "$schema": "./chain.schema.json",
  "version": "1.0.0",
  "config": {
    "sources": [
      {
        "name": "HR Source",
        "sourceType": "authoritative",
        "correlationMode": "none",
        "deferredMatching": true,
        "accountJmespathFilter": "department == 'Engineering'"
      },
      {
        "name": "Payroll Source",
        "sourceType": "authoritative",
        "correlationMode": "none"
      }
    ],
    "uniqueAttributeDefinitions": [
      {
        "name": "employeeId",
        "expression": "$counter",
        "useIncrementalCounter": true,
        "counterStart": 1000,
        "digits": 5,
        "normalize": false,
        "spaces": false,
        "trim": true
      },
      {
        "name": "alias",
        "expression": "#if($account.displayName.contains(\"Admin\"))ALPHA-$UUID#{else}BETA-$counter#{end}",
        "normalize": true,
        "spaces": true,
        "trim": true
      }
    ],
    "normalAttributeDefinitions": [
      {
        "name": "department",
        "expression": "$account.department",
        "refresh": true,
        "normalize": false,
        "spaces": false,
        "trim": true
      },
      {
        "name": "title",
        "expression": "$account.title",
        "refresh": true,
        "normalize": false,
        "spaces": false,
        "trim": true
      }
    ],
    "attributeMaps": [
      {
        "newAttribute": "fullName",
        "existingAttributes": ["displayName"],
        "attributeMerge": "concatenate"
      },
      {
        "newAttribute": "contactEmail",
        "existingAttributes": ["email", "mail"],
        "attributeMerge": "first"
      }
    ],
    "matchingConfigs": [
      {
        "attribute": "displayName",
        "algorithm": "name-matcher",
        "fusionScore": 70
      },
      {
        "attribute": "email",
        "algorithm": "dice",
        "fusionScore": 90,
        "mandatory": false
      }
    ],
    "fusionAverageScore": 80,
    "fusionMergingExactMatch": true,
    "fusionOwnerIsGlobalReviewer": true,
    "fusionFormExpirationDays": 7,
    "includeIdentities": true,
    "deleteEmpty": true,
    "maxHistoryMessages": 20
  },
